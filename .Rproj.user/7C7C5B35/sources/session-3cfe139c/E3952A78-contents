# ============================================================
# 7) Inicializar agenda (next_free) DESDE HOY
#    + contadores para balance
# ============================================================
init_schedule <- function(a, anchor_date = Sys.Date()) {
  
  a <- a %>% mutate(id = as.character(id))
  
  workers <- a %>%
    filter(!is.na(collab_email), collab_email != "",
           collab_userPosition_name %in% WORK_ROLES) %>%
    distinct(collab_email, collab_userPosition_name) %>%
    left_join(workers_allowed, by = "collab_email")
  
  # Si hay workers en workers_allowed pero aún no aparecen en 'a' (porque no tienen tareas asignadas),
  # los metemos también (para que el algoritmo pueda asignarles trabajo).
  extra_workers <- workers_allowed %>%
    transmute(collab_email = as.character(collab_email),
              collab_userPosition_name = NA_character_,
              allowed_codes = allowed_codes)
  
  workers <- bind_rows(
    workers %>% select(collab_email, collab_userPosition_name, allowed_codes),
    extra_workers
  ) %>%
    distinct(collab_email, .keep_all = TRUE)
  
  # "HOY" como inicio del calendario
  sched <- workers %>%
    mutate(
      next_free = day_start(anchor_date),
      # balance por país
      cnt_GT=0L, cnt_CR=0L, cnt_NI=0L, cnt_PA=0L, cnt_SV=0L, cnt_HN=0L,
      # balance general (tareas totales asignadas)
      cnt_total = 0L
    )
  
  sched
}

# ============================================================
# 8) Elegir worker (con opción de "preferido")
#    Reglas:
#      - si hay país: debe estar permitido
#      - si preferido existe y cumple país => gana (siempre)
#      - luego: score = next_free + pen_country + pen_total
# ============================================================
pick_worker <- function(sched, cc, preferred_email = NA_character_) {
  
  cand <- sched
  
  # filtrar por país si hay país
  if (!is.na(cc)) {
    cand <- cand %>%
      filter(!is.na(allowed_codes)) %>%
      filter(vapply(allowed_codes, function(x) cc %in% x, logical(1)))
    if (nrow(cand) == 0) return(NULL)
  }
  
  # si hay preferido y está en candidatos => se respeta
  if (!is.na(preferred_email) && preferred_email != "" &&
      preferred_email %in% cand$collab_email) {
    return(cand %>% filter(collab_email == preferred_email) %>% slice(1))
  }
  
  # penalización por país
  pen_country <- rep(0, nrow(cand))
  if (!is.na(cc)) {
    coln <- paste0("cnt_", cc)
    if (coln %in% names(cand)) pen_country <- cand[[coln]]
  }
  
  # penalización por carga total
  pen_total <- if ("cnt_total" %in% names(cand)) cand$cnt_total else rep(0, nrow(cand))
  
  cand %>%
    mutate(
      score = as.numeric(next_free) +
        pen_country * 1e6 +          # país pesa bastante
        pen_total   * 1e4            # carga total pesa menos
    ) %>%
    arrange(score, collab_email) %>%
    slice(1)
}

# ============================================================
# Helpers: actualizar contadores de balance
# ============================================================
bump_counts <- function(sched, email, cc, add_total = 1L, add_cc = 1L) {
  sched <- sched %>%
    mutate(
      cnt_total = if_else(collab_email == email, cnt_total + add_total, cnt_total)
    )
  
  if (!is.na(cc)) {
    coln <- paste0("cnt_", cc)
    if (coln %in% names(sched)) {
      sched <- sched %>%
        mutate(
          !!coln := if_else(collab_email == email, .data[[coln]] + add_cc, .data[[coln]])
        )
    }
  }
  sched
}

# ============================================================
# 9) NUEVO scheduler:
#    - Replanifica TODO desde HOY
#    - FIFO global por arrival=datetime (usa la fecha original SOLO para orden)
#    - Preferencia por collab_email existente si es válido
#    - Packing micro por (cc_grp, mkind) respetando FIFO dentro del grupo
# ============================================================
schedule_tasks_from_today <- function(a, anchor_date = Sys.Date()) {
  
  a <- a %>% mutate(id = as.character(id))
  
  sched <- init_schedule(a, anchor_date = anchor_date)
  assigned <- list()
  
  # base "todo": incluir asignadas y no asignadas, pero TODO se replanifica
  todo <- a %>%
    mutate(
      arrival = parse_dt(datetime),
      arrival = if_else(is.na(arrival),
                        as.POSIXct("2100-01-01 00:00:00", tz = API_TZ),
                        arrival),
      cc = vapply(tag, tag_to_country, character(1)),
      micro = vapply(tiempo_estimado_dias, is_micro, logical(1)),
      mkind = vapply(tiempo_estimado_dias, micro_kind, character(1)),
      preferred_email = if_else(!is.na(collab_email) & collab_email != "",
                                as.character(collab_email),
                                NA_character_)
    ) %>%
    arrange(arrival, id)
  
  # separar micro vs normal
  normal_tasks <- todo %>% filter(!micro)
  micro_tasks  <- todo %>% filter(micro)
  
  # ----------------------------------------------------------
  # 9A) NORMALES FIFO GLOBAL
  # ----------------------------------------------------------
  for (i in seq_len(nrow(normal_tasks))) {
    trow <- normal_tasks[i, ]
    
    if (is.na(trow$tiempo_estimado_dias)) {
      assigned[[length(assigned)+1]] <- tibble(
        id = trow$id,
        collab_email_new = NA_character_,
        planned_start = as.POSIXct(NA, tz=API_TZ),
        planned_end   = as.POSIXct(NA, tz=API_TZ),
        note = "NO_DURATION"
      )
      next
    }
    
    w <- pick_worker(
      sched,
      cc = trow$cc,
      preferred_email = trow$preferred_email
    )
    
    if (is.null(w)) {
      assigned[[length(assigned)+1]] <- tibble(
        id = trow$id,
        collab_email_new = NA_character_,
        planned_start = as.POSIXct(NA, tz=API_TZ),
        planned_end   = as.POSIXct(NA, tz=API_TZ),
        note = "NO_WORKER_FOR_COUNTRY"
      )
      next
    }
    
    start <- w$next_free
    end <- start + as.difftime(trow$tiempo_estimado_dias * 24, units="hours")
    
    assigned[[length(assigned)+1]] <- tibble(
      id = trow$id,
      collab_email_new = w$collab_email,
      planned_start = start,
      planned_end = end,
      note = ifelse(!is.na(trow$preferred_email) && trow$preferred_email == w$collab_email,
                    "OK_PREFERRED", "OK")
    )
    
    # update next_free + balance
    sched <- sched %>%
      mutate(next_free = if_else(collab_email == w$collab_email, end, next_free))
    sched <- bump_counts(sched, w$collab_email, trow$cc, add_total = 1L, add_cc = 1L)
  }
  
  # ----------------------------------------------------------
  # 9B) MICRO PACKING (1/30, 1/15)
  #     - agrupamos por (cc_grp, mkind) para juntar
  #     - respeta FIFO dentro del grupo (arrival,id)
  #     - preferencia: si la tarea ya tenía owner y ese owner es válido,
  #       intentamos packear en ese owner (siempre que sea candidato).
  # ----------------------------------------------------------
  micro_groups <- micro_tasks %>%
    filter(!is.na(mkind)) %>%
    mutate(cc_grp = if_else(is.na(cc), "NO_COUNTRY", cc)) %>%
    group_by(cc_grp, mkind) %>%
    group_split()
  
  for (g in micro_groups) {
    g <- g %>% arrange(arrival, id)
    
    ccg_raw <- unique(g$cc_grp)[1]
    ccg <- if (ccg_raw == "NO_COUNTRY") NA_character_ else ccg_raw
    
    kind <- unique(g$mkind)[1]
    cap <- micro_cap(kind)
    each_dur <- g$tiempo_estimado_dias[1]
    
    idx <- 1
    while (idx <= nrow(g)) {
      
      # si el primer item del chunk tiene preferido, intentamos usarlo como preferido del bloque
      pref_block <- g$preferred_email[idx]
      if (is.na(pref_block) || pref_block == "") pref_block <- NA_character_
      
      w <- pick_worker(sched, cc = ccg, preferred_email = pref_block)
      
      if (is.null(w)) {
        rest <- g[idx:nrow(g), ]
        assigned[[length(assigned)+1]] <- tibble(
          id = rest$id,
          collab_email_new = NA_character_,
          planned_start = as.POSIXct(NA, tz=API_TZ),
          planned_end   = as.POSIXct(NA, tz=API_TZ),
          note = "NO_WORKER_FOR_COUNTRY"
        )
        break
      }
      
      base_day <- as.Date(w$next_free)
      block_start <- day_start(base_day)
      if (w$next_free > block_start) block_start <- w$next_free
      
      take_n <- min(cap, nrow(g) - idx + 1)
      chunk <- g[idx:(idx + take_n - 1), ]
      
      starts <- block_start + as.difftime((seq_len(take_n)-1) * each_dur * 24, units="hours")
      ends   <- block_start + as.difftime((seq_len(take_n))   * each_dur * 24, units="hours")
      block_end <- max(ends, na.rm=TRUE)
      
      assigned[[length(assigned)+1]] <- tibble(
        id = chunk$id,
        collab_email_new = w$collab_email,
        planned_start = starts,
        planned_end = ends,
        note = ifelse(!is.na(pref_block) && pref_block == w$collab_email,
                      paste0("OK_MICRO_PACK_", cap, "_PREFERRED"),
                      paste0("OK_MICRO_PACK_", cap))
      )
      
      # update schedule + balance
      sched <- sched %>%
        mutate(next_free = if_else(collab_email == w$collab_email, block_end, next_free))
      
      # balance: micro cuenta como varias tareas
      sched <- bump_counts(sched, w$collab_email, ccg, add_total = take_n, add_cc = take_n)
      
      idx <- idx + take_n
    }
  }
  
  # ----------------------------------------------------------
  # JOIN FINAL (limpio)
  # ----------------------------------------------------------
  assigned_df <- bind_rows(assigned) %>%
    mutate(id = as.character(id))
  
  a_plan <- a %>%
    mutate(id = as.character(id)) %>%
    select(-any_of(c("planned_start","planned_end","note","collab_email_plan","collab_email_new"))) %>%
    left_join(assigned_df, by = "id") %>%
    mutate(
      collab_email_plan = collab_email_new
    ) %>%
    select(-collab_email_new)
  
  list(a_plan = a_plan, schedule = sched, assignments = assigned_df)
}

# ============================================================
# 10) RUN
