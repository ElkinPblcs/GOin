# ============================================================
# 2) Inferir "skill_main" desde skill_names (prioridad)
# ============================================================
infer_skill_main <- function(skill_names) {
  if (is.na(skill_names) || str_squish(skill_names) == "") return(NA_character_)
  x <- toupper(skill_names)
  
  if (str_detect(x, "ADAPTACIONES|ADAP")) return("ADAPTACIONES")
  if (str_detect(x, "\\bPRO\\b")) return("PRO")
  if (str_detect(x, "\\bPLUS\\b")) return("PLUS")
  if (str_detect(x, "EST[ÁA]NDAR|\\bESTANDAR\\b")) return("ESTÁNDAR")
  NA_character_
}

# ============================================================
# 3) Normalizar typeTask para SLA
# ============================================================
normalize_typeTask_for_sla <- function(typeTask_name, skill_main) {
  if (!is.na(skill_main) && skill_main == "ADAPTACIONES") return("ADAP")
  if (is.na(typeTask_name) || str_squish(typeTask_name) == "") return(NA_character_)
  
  x <- tolower(str_squish(typeTask_name))
  if (str_detect(x, "est[aá]tic")) return("Key Visual Estático")
  if (str_detect(x, "animad"))     return("Key Visual Animado")
  
  str_squish(typeTask_name)
}

