# ----------------------------
# Auth
# ----------------------------
get_token <- function() {
  basic <- openssl::base64_encode(charToRaw(paste0(COR_API_KEY, ":", COR_CLIENT_SECRET)))
  r <- POST(
    url = paste0(API_BASE, "/oauth/token"),
    query = list(grant_type = "client_credentials"),
    add_headers(Authorization = paste("Basic", basic), Accept = "application/json")
  )
  stop_for_status(r)
  content(r, as = "parsed", type = "application/json")$access_token
}

# ----------------------------
# GET /tasks (paginado) filtrado por status
# ----------------------------
get_tasks_by_status_paged <- function(token, status_value, per_page = 200) {
  filters_json <- toJSON(list(status = status_value), auto_unbox = TRUE)
  
  page <- 1
  out <- list()
  
  repeat {
    r <- GET(
      url = paste0(API_BASE, "/tasks"),
      query = list(
        page = page,
        perPage = per_page,
        filters = filters_json
      ),
      add_headers(Authorization = paste("Bearer", token), Accept = "application/json")
    )
    stop_for_status(r)
    
    payload <- content(r, as = "parsed", type = "application/json")
    rows <- payload$data
    if (is.null(rows) || length(rows) == 0) break
    
    out[[length(out) + 1]] <- fromJSON(toJSON(rows), flatten = TRUE)
    
    if (!is.null(payload$lastPage) && !is.null(payload$page) && payload$page >= payload$lastPage) break
    page <- page + 1
  }
  
  if (length(out) == 0) return(data.frame())
  dplyr::bind_rows(out)
}

# ----------------------------
# Flatten: primer colaborador
# ----------------------------
get_first_collab <- function(x) {
  if (is.null(x) || length(x) == 0) return(NULL)
  
  if (is.data.frame(x)) {
    if (nrow(x) == 0) return(NULL)
    return(as.list(x[1, , drop = FALSE]))
  }
  
  if (is.list(x)) {
    first <- x[[1]]
    if (is.null(first)) return(NULL)
    
    if (is.data.frame(first)) {
      if (nrow(first) == 0) return(NULL)
      return(as.list(first[1, , drop = FALSE]))
    }
    if (is.list(first)) return(first)
  }
  
  NULL
}

# ----------------------------
# NUEVO: GET /tasks/{id}
# ----------------------------
get_task_by_id <- function(token, task_id) {
  r <- GET(
    url = paste0(API_BASE, "/tasks/", task_id),
    add_headers(Authorization = paste("Bearer", token), Accept = "application/json")
  )
  stop_for_status(r)
  content(r, as = "parsed", type = "application/json")
}

# ----------------------------
# NUEVO: skill => 1 idioma por label_id (preferido "es")
# Devuelve string: "Gross | PLUS | Reloads"
# ----------------------------
extract_skills_one_lang <- function(skill_list, preferred_lang = "es") {
  if (is.null(skill_list) || length(skill_list) == 0) return(NA_character_)
  
  df <- tryCatch(fromJSON(toJSON(skill_list), flatten = TRUE), error = function(e) NULL)
  if (is.null(df) || nrow(df) == 0) return(NA_character_)
  
  df$lang <- tolower(as.character(df$lang))
  df$label_id <- as.character(df$label_id)
  df$name <- trimws(as.character(df$name))
  
  picked <- df %>%
    group_by(label_id) %>%
    arrange(desc(lang == tolower(preferred_lang))) %>%  # preferred primero
    slice(1) %>%
    ungroup()
  
  out <- unique(picked$name)
  out <- out[!is.na(out) & out != ""]
  if (length(out) == 0) return(NA_character_)
  paste(out, collapse = " | ")
}

# ----------------------------
# NUEVO: typeTask name (typeTask$names[[1]]$name)
# ----------------------------
extract_typeTask_name <- function(typeTask_obj) {
  if (is.null(typeTask_obj) || is.null(typeTask_obj$names)) return(NA_character_)
  nm <- typeTask_obj$names
  if (is.list(nm) && length(nm) > 0 && is.list(nm[[1]]) && !is.null(nm[[1]]$name)) {
    return(as.character(nm[[1]]$name)[1])
  }
  NA_character_
}

# ----------------------------
# NUEVO: Enriquecer IDs con (skill_names, typeTask_name)
# ----------------------------
enrich_tasks_with_details <- function(token, task_ids, preferred_lang = "es", pause_sec = 0.05) {
  task_ids <- unique(as.character(task_ids))
  
  rows <- lapply(task_ids, function(tid) {
    if (!is.null(pause_sec) && pause_sec > 0) Sys.sleep(pause_sec)
    
    payload <- tryCatch(get_task_by_id(token, tid), error = function(e) NULL)
    if (is.null(payload)) {
      return(data.frame(
        id = as.character(tid),
        skill_names = NA_character_,
        typeTask_name = NA_character_,
        stringsAsFactors = FALSE
      ))
    }
    
    data.frame(
      id = as.character(payload$id),
      skill_names = extract_skills_one_lang(payload$skill, preferred_lang = preferred_lang),
      typeTask_name = extract_typeTask_name(payload$typeTask),
      stringsAsFactors = FALSE
    )
  })
  
  bind_rows(rows)
}

